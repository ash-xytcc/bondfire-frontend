{
  "name": "bondfire-redharbor-bootstrap",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:web": "npm --workspace apps/redharbor-web run dev",
    "dev:ops": "npm --workspace apps/redharbor-ops run dev",
    "build:web": "npm --workspace apps/redharbor-web run build",
    "build:ops": "npm --workspace apps/redharbor-ops run build"
  }
}
